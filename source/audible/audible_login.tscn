[node name="FinishBtn" type="Button" parent="Center/Panel/VBox/Step2/Row"]
unique_name_in_owner = true
layout_mode = 2
theme_type_variation = &"Primary"
text = "Finish sign-in"

[node name="StatusLabel" type="Label" parent="Center/Panel/VBox"]
unique_name_in_owner = true
layout_mode = 2
