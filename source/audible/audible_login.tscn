[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://source/audible/audible_login.gd" id="1_login"]

[node name="AudibleLogin" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1_login")

[node name="Dim" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.043, 0.062, 0.09, 0.7)

[node name="Center" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0

[node name="Panel" type="PanelContainer" parent="Center"]
custom_minimum_size = Vector2(560, 0)
layout_mode = 2
theme_type_variation = &"Dialog"

[node name="VBox" type="VBoxContainer" parent="Center/Panel"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="Header" type="HBoxContainer" parent="Center/Panel/VBox"]
layout_mode = 2

[node name="Title" type="Label" parent="Center/Panel/VBox/Header"]
layout_mode = 2
size_flags_horizontal = 3
theme_type_variation = &"Title"
text = "Connect Audible account"

[node name="CloseBtn" type="Button" parent="Center/Panel/VBox/Header"]
unique_name_in_owner = true
layout_mode = 2
text = "✕"

[node name="Intro" type="Label" parent="Center/Panel/VBox"]
layout_mode = 2
theme_type_variation = &"Muted"
text = "Sign in through Amazon's own page in your browser — your password, CAPTCHA and 2FA stay with Amazon. This app only receives a device token."
autowrap_mode = 2

[node name="Step1" type="HBoxContainer" parent="Center/Panel/VBox"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="CountryLabel" type="Label" parent="Center/Panel/VBox/Step1"]
layout_mode = 2
size_flags_vertical = 4
theme_type_variation = &"Muted"
text = "Marketplace"

[node name="CountryOption" type="OptionButton" parent="Center/Panel/VBox/Step1"]
unique_name_in_owner = true
layout_mode = 2

[node name="OpenBtn" type="Button" parent="Center/Panel/VBox/Step1"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_type_variation = &"Primary"
text = "Open Amazon sign-in"

[node name="Step2" type="VBoxContainer" parent="Center/Panel/VBox"]
unique_name_in_owner = true
visible = false
layout_mode = 2
theme_override_constants/separation = 8

[node name="Sep" type="HSeparator" parent="Center/Panel/VBox/Step2"]
layout_mode = 2

[node name="PasteLabel" type="Label" parent="Center/Panel/VBox/Step2"]
layout_mode = 2
theme_type_variation = &"Muted"
text = "Paste the address your browser landed on:"

[node name="Row" type="HBoxContainer" parent="Center/Panel/VBox/Step2"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="RedirectEdit" type="LineEdit" parent="Center/Panel/VBox/Step2/Row"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
