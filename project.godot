; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Audiobooks"
run/main_scene="res://source/app/main.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

Palette="*res://source/core/palette.gd"
Settings="*res://source/core/settings.gd"
Library="*res://source/core/library.gd"
Transcoder="*res://source/core/transcoder.gd"
Player="*res://source/core/player.gd"
Audible="*res://source/audible/audible.gd"

[display]

window/size/viewport_width=1180
window/size/viewport_height=820
window/size/window_width_override=1180
window/size/window_height_override=820
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[gui]

theme/custom="res://assets/theme/default_theme.tres"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
textures/vram_compression/import_etc2_astc=true
environment/defaults/default_clear_color=Color(0.043, 0.078, 0.122, 1)
